# Server Configuration
NODE_ENV=development
API_PORT=3001

# Ethereum RPC Endpoints
# Public RPCs (free but may have rate limits)
ETHEREUM_MAINNET_RPC=https://eth.public-rpc.com
ETHEREUM_SEPOLIA_RPC=https://rpc.sepolia.org
ETHEREUM_GOERLI_RPC=https://rpc.ankr.com/eth_goerli

# Or use Infura (recommended - get free API key at https://infura.io)
# ETHEREUM_MAINNET_RPC=https://mainnet.infura.io/v3/YOUR_INFURA_API_KEY
# ETHEREUM_SEPOLIA_RPC=https://sepolia.infura.io/v3/YOUR_INFURA_API_KEY
# ETHEREUM_GOERLI_RPC=https://goerli.infura.io/v3/YOUR_INFURA_API_KEY

# Or use Alchemy (recommended - get free API key at https://alchemy.com)
# ETHEREUM_MAINNET_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
# ETHEREUM_SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# API Keys (optional but highly recommended for production)
# Etherscan - for transaction history (https://etherscan.io/apis)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Infura - for Ethereum RPC (https://infura.io)
INFURA_API_KEY=your_infura_api_key_here

# Alchemy - for Ethereum RPC (https://alchemy.com)
ALCHEMY_API_KEY=your_alchemy_api_key_here

# BlockCypher - for Bitcoin API (https://accounts.blockcypher.com)
BLOCKCYPHER_API_KEY=your_blockcypher_api_key_here

# CoinGecko API (https://www.coingecko.com/en/api)
COINGECKO_API_KEY=your_coingecko_api_key_here

# Bitcoin Configuration
BITCOIN_NETWORK=mainnet
BITCOIN_TESTNET_NETWORK=testnet

# Security (IMPORTANT: Change these in production!)
JWT_SECRET=change-this-to-a-random-32-character-string
ENCRYPTION_KEY=change-this-to-a-random-32-character-string

# Google OAuth Configuration (Optional - for Google Sign-In)
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# Clerk Authentication (Recommended - replaces Google OAuth)
# Get credentials from: https://dashboard.clerk.com/
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# CORS - Add your frontend URLs
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3003

# ─────────────────────────────────────────────────────────────
# Telegram AI Agent Bot
# ─────────────────────────────────────────────────────────────

# Telegram Bot Token — get from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Random 64-hex secret to verify webhook calls really come from Telegram
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=your_random_64_hex_secret_here

# Backend URL for webhook registration (no trailing slash)
BACKEND_URL=https://your-backend.railway.app

# Server Signing Key — EOA private key used to encrypt/decrypt per-user bot wallets
# Generate with: node backend/scripts/generateServerKey.js
SERVER_SIGNING_KEY=0xyour_server_private_key_here
SERVER_SIGNING_ADDRESS=0xyour_server_address_here

# Google Gemini API Key — for natural language intent parsing
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Default chain for bot transactions (11155111 = Sepolia testnet for dev, 1 = Ethereum mainnet)
BOT_DEFAULT_CHAIN_ID=11155111
