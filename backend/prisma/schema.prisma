// ============================================================================
// Walletrix Database Schema
// Hybrid EOA + ERC-4337 Smart Vault Architecture
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// Core User & Wallet Models
// ============================================================================

/// A Walletrix user account (authenticated via Clerk or JWT)
model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  passwordHash      String    @map("password_hash")
  avatarUrl         String?   @map("avatar_url")
  telegramId        String?   @unique @map("telegram_id")
  telegramLinkedAt  DateTime? @map("telegram_linked_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  wallets           Wallet[]
  activityLogs      ActivityLog[]
  telegramLinkCode  TelegramLinkCode?
  telegramBotWallet TelegramBotWallet?
  savedRecipients   SavedRecipient[]
  stealthProfiles   StealthWalletProfile[]

  @@map("users")
}

/// One-time link code for connecting a Telegram account to a Walletrix user.
model TelegramLinkCode {
  id         String   @id @default(cuid())
  userId     String   @unique @map("user_id")
  code       String   @unique
  telegramId String   @map("telegram_id")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("telegram_link_codes")
}

/// A dedicated bot EOA wallet generated per user for Telegram-initiated transactions.
/// Private key is encrypted with the server-side SERVER_SIGNING_KEY.
model TelegramBotWallet {
  id                   String   @id @default(cuid())
  userId               String   @unique @map("user_id")
  address              String   @unique
  encryptedPrivateKey  String   @map("encrypted_private_key") @db.Text
  createdAt            DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("telegram_bot_wallets")
}

/// Persistent conversational state for Telegram bot interactions.
/// Used to preserve context between messages and across process restarts.
model ConversationSession {
  id           String   @id @default(cuid())
  telegramId   String   @unique @map("telegram_id")
  chatContext  Json?    @map("chat_context")
  transferDraft Json?   @map("transfer_draft")
  pendingIntent Json?   @map("pending_intent")
  expiresAt    DateTime? @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([expiresAt])
  @@map("conversation_sessions")
}

/// User-managed saved recipients for Telegram/app send flows.
model SavedRecipient {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  name           String
  normalizedName String   @map("normalized_name")
  address        String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, normalizedName])
  @@index([userId])
  @@map("saved_recipients")
}

/// A long-lived stealth receive profile bound to a user-selected destination wallet.
/// Profiles hold the scan/spend keypair and emit one-time stealth receive addresses.
model StealthWalletProfile {
  id                       String             @id @default(cuid())
  userId                   String             @map("user_id")
  walletType               StealthWalletType  @map("wallet_type")
  walletRef                String             @map("wallet_ref")
  walletLabel              String             @map("wallet_label")
  network                  Network            @default(ETHEREUM)
  scanPublicKey            String             @map("scan_public_key")
  spendPublicKey           String             @map("spend_public_key")
  encryptedScanPrivateKey  String             @map("encrypted_scan_private_key") @db.Text
  encryptedSpendPrivateKey String             @map("encrypted_spend_private_key") @db.Text
  stealthMetaAddress       String             @map("stealth_meta_address") @db.Text
  createdAt                DateTime           @default(now()) @map("created_at")
  updatedAt                DateTime           @updatedAt @map("updated_at")

  user   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  issues StealthAddressIssue[]

  @@unique([userId, walletType, walletRef, network])
  @@index([userId])
  @@map("stealth_wallet_profiles")
}

/// A one-time stealth receive address issued from a profile.
model StealthAddressIssue {
  id                String               @id @default(cuid())
  profileId         String               @map("profile_id")
  stealthAddress    String               @map("stealth_address")
  ephemeralPublicKey String              @map("ephemeral_public_key")
  network           Network              @default(ETHEREUM)
  destinationAddress String              @map("destination_address")
  status            StealthAddressStatus @default(ACTIVE)
  createdAt         DateTime             @default(now()) @map("created_at")
  usedAt            DateTime?            @map("used_at")
  expiresAt         DateTime?            @map("expires_at")
  lastCheckedAt     DateTime?            @map("last_checked_at")
  lastObservedBalanceWei String?         @map("last_observed_balance_wei")
  claimedAt         DateTime?            @map("claimed_at")
  claimTxHash       String?              @map("claim_tx_hash")

  profile StealthWalletProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@unique([profileId, stealthAddress])
  @@index([stealthAddress])
  @@index([status])
  @@index([status, network])
  @@map("stealth_address_issues")
}

enum StealthWalletType {
  ACCOUNT_WALLET
  TELEGRAM_BOT_WALLET
}

enum StealthAddressStatus {
  ACTIVE
  FUNDED
  CLAIMED
  EXPIRED
}

/// Represents a wallet (EOA) derived from BIP-39 or imported via private key.
/// This is the foundation — on EVM chains, a SmartAccount can optionally be
/// deployed on top of this wallet to enable ERC-4337 features.
model Wallet {
  id           String     @id @default(cuid())
  userId       String     @map("user_id")
  label        String     @default("My Wallet")
  type         WalletType @default(HD)
  network      Network    @default(ETHEREUM)
  address      String
  encryptedKey String?    @map("encrypted_key") @db.Text
  metadata     Json?
  isActive     Boolean    @default(true) @map("is_active")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  smartAccount  SmartAccount?
  transactions  Transaction[]

  @@unique([userId, address, network])
  @@index([userId])
  @@index([address])
  @@map("wallets")
}

enum WalletType {
  HD       // Derived from BIP-39 mnemonic
  IMPORTED // Imported via private key
}

enum Network {
  ETHEREUM
  POLYGON
  ARBITRUM
  OPTIMISM
  BASE
  BSC
  AVALANCHE
  BITCOIN
  SOLANA
  SEPOLIA
  GOERLI
  HOLESKY
}

// ============================================================================
// ERC-4337 Smart Vault Models (Hybrid Architecture)
// ============================================================================

/// An ERC-4337 Smart Account (WalletrixVault) deployed on top of an EOA wallet.
/// The EOA acts as the signer/owner; the SmartAccount holds funds on-chain.
model SmartAccount {
  id           String   @id @default(cuid())
  walletId     String   @unique @map("wallet_id")
  vaultAddress String   @map("vault_address")
  chainId      Int      @map("chain_id")
  factorySalt  String   @map("factory_salt")
  isDeployed   Boolean  @default(false) @map("is_deployed")
  deployTxHash String?  @map("deploy_tx_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  wallet    Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)
  guardians Guardian[]
  userOps   UserOperation[]

  @@unique([vaultAddress, chainId])
  @@index([walletId])
  @@map("smart_accounts")
}

/// A guardian in the social recovery system.
/// M-of-N guardians must approve to recover a SmartAccount.
model Guardian {
  id              String   @id @default(cuid())
  smartAccountId  String   @map("smart_account_id")
  guardianAddress String   @map("guardian_address")
  label           String?
  isActive        Boolean  @default(true) @map("is_active")
  addedAt         DateTime @default(now()) @map("added_at")

  smartAccount SmartAccount @relation(fields: [smartAccountId], references: [id], onDelete: Cascade)

  @@unique([smartAccountId, guardianAddress])
  @@index([smartAccountId])
  @@map("guardians")
}

/// A meta-transaction submitted via the ERC-4337 bundler.
model UserOperation {
  id              String          @id @default(cuid())
  smartAccountId  String          @map("smart_account_id")
  userOpHash      String          @unique @map("user_op_hash")
  status          UserOpStatus    @default(PENDING)
  bundlerResponse Json?           @map("bundler_response")
  createdAt       DateTime        @default(now()) @map("created_at")
  executedAt      DateTime?       @map("executed_at")

  smartAccount SmartAccount @relation(fields: [smartAccountId], references: [id], onDelete: Cascade)

  @@index([smartAccountId])
  @@index([status])
  @@map("user_operations")
}

enum UserOpStatus {
  PENDING
  BUNDLED
  CONFIRMED
  FAILED
}

// ============================================================================
// Transaction & Activity Tracking
// ============================================================================

/// Records on-chain transactions (both EOA and Smart Vault).
model Transaction {
  id          String            @id @default(cuid())
  walletId    String            @map("wallet_id")
  txHash      String            @map("tx_hash")
  network     Network
  fromAddress String            @map("from_address")
  toAddress   String            @map("to_address")
  value       String            // Stored as string to handle BigInt safely
  status      TransactionStatus @default(PENDING)
  category    TxCategory        @default(TRANSFER)
  gasUsed     String?           @map("gas_used")
  timestamp   DateTime          @default(now())
  metadata    Json?

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([txHash])
  @@index([status])
  @@map("transactions")
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum TxCategory {
  TRANSFER
  SWAP
  APPROVE
  DEPLOY
  RECOVERY
  BATCH
}

/// Audit log for user actions (wallet creation, settings changes, etc.)
model ActivityLog {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  action    String
  details   Json?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}
